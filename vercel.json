{
  "redirects": [
    { "source": "/", "destination": "/intro.html", "permanent": false }
  ],
  "rewrites": [
    { "source": "/app", "destination": "/smart-city.html" },
    { "source": "/map-classic", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/intro.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
