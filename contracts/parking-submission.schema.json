{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://soulflame.bg/contracts/parking-submission.schema.json",
  "title": "SmartCity parking proposal submission",
  "type": "object",
  "additionalProperties": false,
  "required": ["clientSubmissionId", "name", "geometry", "access", "evidence"],
  "properties": {
    "clientSubmissionId": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_-]{8,80}$"
    },
    "name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 160
    },
    "geometry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "coordinates"],
      "properties": {
        "type": { "const": "Polygon" },
        "coordinates": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "items": {
            "type": "array",
            "minItems": 4,
            "maxItems": 500,
            "items": {
              "type": "array",
              "prefixItems": [
                { "type": "number", "minimum": 22.3, "maximum": 28.7 },
                { "type": "number", "minimum": 41.2, "maximum": 44.3 }
              ],
              "items": false,
              "minItems": 2,
              "maxItems": 2
            }
          }
        }
      }
    },
    "vehicleEntrance": {
      "$ref": "#/$defs/point"
    },
    "pedestrianExit": {
      "$ref": "#/$defs/point"
    },
    "access": {
      "type": "string",
      "enum": ["public", "customers", "private", "residents", "unknown"]
    },
    "capacity": {
      "type": ["integer", "null"],
      "minimum": 1,
      "maximum": 100000
    },
    "fee": {
      "type": ["string", "null"],
      "maxLength": 120
    },
    "openingHours": {
      "type": ["string", "null"],
      "maxLength": 255
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["note"],
      "properties": {
        "note": { "type": "string", "minLength": 3, "maxLength": 2000 },
        "capturedAt": { "type": ["string", "null"], "format": "date-time" },
        "uploadToken": { "type": ["string", "null"], "maxLength": 300 }
      }
    }
  },
  "$defs": {
    "point": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["type", "coordinates"],
      "properties": {
        "type": { "const": "Point" },
        "coordinates": {
          "type": "array",
          "prefixItems": [
            { "type": "number", "minimum": 22.3, "maximum": 28.7 },
            { "type": "number", "minimum": 41.2, "maximum": 44.3 }
          ],
          "items": false,
          "minItems": 2,
          "maxItems": 2
        }
      }
    }
  }
}
