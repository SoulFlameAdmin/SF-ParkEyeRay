{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartcity.soulflame.bg/contracts/parking-import.schema.json",
  "title": "SmartCity parking import batch",
  "type": "object",
  "additionalProperties": false,
  "required": ["source", "scopeKey", "revision", "features"],
  "properties": {
    "source": {
      "type": "string",
      "enum": ["osm", "operator", "municipality"]
    },
    "scopeKey": {
      "type": "string",
      "minLength": 2,
      "maxLength": 120,
      "pattern": "^[a-zA-Z0-9._:-]+$"
    },
    "revision": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "bbox": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["type", "coordinates"],
      "properties": {
        "type": { "const": "Polygon" },
        "coordinates": { "type": "array", "minItems": 1 }
      }
    },
    "sourceUpdatedAt": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "features": {
      "type": "array",
      "maxItems": 50000,
      "items": { "$ref": "#/$defs/feature" }
    }
  },
  "$defs": {
    "point": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "coordinates"],
      "properties": {
        "type": { "const": "Point" },
        "coordinates": {
          "type": "array",
          "prefixItems": [
            { "type": "number", "minimum": 22.2, "maximum": 28.75 },
            { "type": "number", "minimum": 41.1, "maximum": 44.3 }
          ],
          "minItems": 2,
          "maxItems": 2
        }
      }
    },
    "geometry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "coordinates"],
      "properties": {
        "type": { "type": "string", "enum": ["Point", "LineString", "Polygon"] },
        "coordinates": { "type": "array", "minItems": 1 }
      }
    },
    "feature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["externalId", "featureType", "kind", "geometry", "representativePoint"],
      "properties": {
        "externalId": { "type": "string", "minLength": 1, "maxLength": 180 },
        "featureType": { "type": "string", "enum": ["area", "space", "street", "entrance", "point"] },
        "name": { "type": ["string", "null"], "maxLength": 200 },
        "kind": { "type": "string", "minLength": 1, "maxLength": 80 },
        "geometry": { "$ref": "#/$defs/geometry" },
        "representativePoint": { "$ref": "#/$defs/point" },
        "vehicleEntrance": { "anyOf": [{ "$ref": "#/$defs/point" }, { "type": "null" }] },
        "access": { "type": ["string", "null"], "maxLength": 80 },
        "capacity": { "type": ["integer", "null"], "minimum": 1, "maximum": 100000 },
        "fee": { "type": ["string", "null"], "maxLength": 80 },
        "covered": { "type": ["boolean", "null"] },
        "lit": { "type": ["boolean", "null"] },
        "surveillance": { "type": ["boolean", "null"] },
        "tags": { "type": "object" },
        "sourceUpdatedAt": { "type": ["string", "null"], "format": "date-time" }
      }
    }
  }
}
